{
  "name": "asistencia-backend",
  "version": "1.0.0",
  "description": "API del sistema de control de asistencia",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "check": "node --check src/server.js",
    "migrate": "node src/scripts/run-migrations.js",
