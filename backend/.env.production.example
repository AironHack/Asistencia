APP_ENV=production
APP_PORT=3000
APP_TIMEZONE=America/Lima

# Cambia esto por el dominio real del frontend publicado.
FRONTEND_ORIGIN=https://asistencia.tu-dominio.com

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=asistencia_db
DB_USERNAME=asistencia_user
DB_PASSWORD=CAMBIA_ESTA_CLAVE_DE_BASE_DATOS

# Usa secretos largos, aleatorios y distintos.
JWT_ACCESS_SECRET=CAMBIA_ESTE_SECRETO_ACCESS_DE_32_CARACTERES_MINIMO
JWT_REFRESH_SECRET=CAMBIA_ESTE_SECRETO_REFRESH_DE_32_CARACTERES_MINIMO
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

QR_HMAC_SECRET=CAMBIA_ESTE_SECRETO_QR_DE_32_CARACTERES_MINIMO
QR_EXPIRES_SECONDS=300

BCRYPT_ROUNDS=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
LOGIN_LOCK_MINUTES=10

FACE_RECOGNITION_ENABLED=true
FACE_CONFIDENCE_MIN=0.85
